# ============================================================
# RAG_Project 环境变量模板
# 复制为 .env 后填入真实密钥（.env 已加入 .gitignore）
# ============================================================

# ── LLM ──────────────────────────────────────────────────────
RAG_DEFAULT_LLM_MODEL=deepseek-chat
RAG_DEEPSEEK_API_KEY=your-deepseek-api-key-here
RAG_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
RAG_QWEN_API_KEY=your-qwen-api-key-here
RAG_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Embedding ────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=text-embedding-v4
RAG_EMBEDDING_API_KEY=your-dashscope-api-key-here
RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_EMBEDDING_BATCH_SIZE=10

# ── ChromaDB ─────────────────────────────────────────────────
RAG_CHROMA_HOST=localhost
RAG_CHROMA_PORT=8001

# ── PostgreSQL ───────────────────────────────────────────────
RAG_POSTGRES_DSN=postgresql://raguser:your-password@localhost:5432/ragdb
RAG_POSTGRES_MIN_POOL=2
RAG_POSTGRES_MAX_POOL=10
RAG_PG_PASSWORD=your-postgres-password

# ── Redis ────────────────────────────────────────────────────
RAG_REDIS_HOST=localhost
RAG_REDIS_PORT=6379
RAG_REDIS_DB=0

# ── RAG 参数 ─────────────────────────────────────────────────
RAG_CHUNK_SIZE=256
RAG_CHUNK_OVERLAP=50
RAG_PARENT_CHUNK_SIZE=1024
RAG_RETRIEVAL_TOP_K=20
RAG_RERANK_MODEL=qwen3-rerank
RAG_RERANK_TOP_K=5
RAG_RRF_K=60
RAG_RRF_TOP_K=20

# ── 超时配置 (秒) ────────────────────────────────────────────
RAG_RETRIEVAL_TIMEOUT_S=5.0
RAG_RERANK_TIMEOUT_S=10.0
RAG_COMPRESS_TIMEOUT_S=5.0
RAG_LLM_TIMEOUT_S=30.0
RAG_GLOBAL_TIMEOUT_S=18.0

# ── LangFuse ─────────────────────────────────────────────────
RAG_LANGFUSE_ENABLED=true
RAG_LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
RAG_LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
RAG_LANGFUSE_HOST=http://localhost:3001
RAG_LANGFUSE_DB_PASSWORD=your-langfuse-db-password
RAG_LANGFUSE_AUTH_SECRET=your-langfuse-auth-secret
RAG_LANGFUSE_SALT=your-langfuse-salt
RAG_LANGFUSE_ENCRYPTION_KEY=your-langfuse-encryption-key

# ── JWT 认证 ─────────────────────────────────────────────────
RAG_JWT_SECRET=your-jwt-secret-change-in-production
RAG_JWT_EXPIRE_HOURS=24
RAG_REGISTRATION_ENABLED=True
RAG_ADMIN_SECRET_CODE=your-admin-secret-code

# ── Ingestion 质量 ──────────────────────────────────────────
RAG_INGESTION_MIN_QUALITY_SCORE=0.30
RAG_INGESTION_MIN_CHUNK_LENGTH=20

# ── RAG 检索 ──────────────────────────────────────────────────
# Tier1 quality gate 向量余弦相似度阈值（值域 0~1），低于此值升级到 Tier2
RAG_TIER1_SCORE_THRESHOLD=0.7

# ── 应用 ─────────────────────────────────────────────────────
RAG_APP_HOST=0.0.0.0
RAG_APP_PORT=8000
RAG_LOG_LEVEL=INFO
RAG_AUTH_ENABLED=true

# ── MCP Server ───────────────────────────────────────────────
# Streamable HTTP 挂载开关（默认 false；true 时 /mcp 生效且必须配置 API Key）
RAG_MCP_ENABLED=false
# HTTP 传输 API Key，≥16 字符（Host 侧以 Authorization: Bearer <key> 或 X-API-Key 传入）
RAG_MCP_API_KEY=
# MCP 工具调用的服务身份 user_id（空 = 匿名，仅可见 public 知识库）
RAG_MCP_USER_ID=
# rag_search 默认返回 chunk 数
RAG_MCP_DEFAULT_TOP_K=5
# MCP server 名称（Host 侧展示）
RAG_MCP_SERVER_NAME=enterprise-rag

